# 应用配置
APP_NAME=EventDrive
APP_VERSION=1.0.0
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置
DATABASE_URL=sqlite:///./data/db.sqlite3

# 抓取配置
CRAWL_INTERVAL_HOURS=6
NEWS_PER_SOURCE=10
NEWS_TIME_RANGE_HOURS=24

# 反爬虫配置
MIN_DELAY=2
MAX_DELAY=5

# 图片存储路径
IMAGES_DIR=./data/images

# 飞书推送配置 (可选)
# 获取方式: 飞书开放平台 -> 群机器人 -> Webhook
# FEISHU_WEBHOOK_URL= https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# FEISHU_SECRET= xxx (可选，留空则不启用签名验证)
# FEISHU_KEYWORD=头条 (推送消息必须包含此关键词才发送)

# 纽约时报飞书推送配置 (可选)
# NYT_FEISHU_WEBHOOK_URL= https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# NYT_FEISHU_SECRET= xxx (可选，留空则不启用签名验证)
# NYT_FEISHU_KEYWORD=HOT (推送消息必须包含此关键词才发送)
